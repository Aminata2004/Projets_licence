# local = affiche les erreurs PHP à l'écran (pratique en dev)
# production = masque les erreurs et les journalise dans logs/php_errors.log
APP_ENV=production

BASE_URL=http://localhost:8080/Gestion_compagnie_mcv/public

DB_NAME=db_compagnies_mvc
DB_HOST=localhost
DB_USERNAME=root
DB_PASSWORD=
DB_DRIVER=mysql

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
# tls (STARTTLS, port 587 en général) ou ssl (SSL/TLS implicite, port 465 en général)
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_NAME=Airbarry

# Impression thermique des billets : "network" ou "usb"
PRINTER_MODE=network
# Utilisés si PRINTER_MODE=network
PRINTER_IP=192.168.1.100
PRINTER_PORT=9100
# Utilisé si PRINTER_MODE=usb : nom exact de l'imprimante installée sous Windows
# (Panneau de configuration > Imprimantes), ou chemin du périphérique sous Linux (ex: /dev/usb/lp0)
PRINTER_USB_NAME=POS-80
