<IfModule mod_rewrite.c>
    RewriteEngine On

    # Si le fichier ou le dossier demandé existe, on l'affiche directement
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f

    # Sinon, on redirige tout vers index.php avec le paramètre url
    RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]
</IfModule>
