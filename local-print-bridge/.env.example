# Config du pont d'impression local pour CE poste de comptoir.
# Copier ce fichier en ".env" (même dossier) et ajuster selon l'imprimante branchée ici.

# "network" (imprimante avec IP fixe sur le réseau local) ou "usb" (branchée sur ce poste)
PRINTER_MODE=network

# Utilisés si PRINTER_MODE=network
PRINTER_IP=192.168.1.100
PRINTER_PORT=9100

# Utilisé si PRINTER_MODE=usb : nom exact de l'imprimante installée sous Windows
# (Panneau de configuration > Imprimantes), ou chemin du périphérique sous Linux (ex: /dev/usb/lp0)
PRINTER_USB_NAME=POS-80

# Domaines autorisés à appeler ce pont (le(s) site(s) qui affichent le bouton d'impression),
# séparés par des virgules. Sans ça, aucun navigateur ne pourra appeler le pont (CORS bloqué).
ALLOWED_ORIGINS=https://annexpress.malitecnologie.com,https://devannexpress.malitecnologie.com,http://localhost
